# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:password@db.example.supabase.co:5432/postgres

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-change-me

# Solana Configuration
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_NETWORK=devnet
NEXT_PUBLIC_WALLET_AUTOCONNECT=true

# Program — MUST update after `anchor deploy`
NEXT_PUBLIC_PROGRAM_ID=YOUR_PROGRAM_ID

# ElevenLabs API for Audio Briefs
ELEVENLABS_API_KEY=YOUR_API_KEY
NEXT_PUBLIC_ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# OpenAI for enhanced AI features
# OPENAI_API_KEY=YOUR_API_KEY

# Environment
NODE_ENV=development
