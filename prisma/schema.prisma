generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TUTOR
  VOLUNTEER
  ADMIN
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String
  name            String?
  walletAddress   String?  @unique
  role            Role     @default(STUDENT)
  reputationScore Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  mentorSessions   MentorshipSession[] @relation("mentor")
  studentSessions  MentorshipSession[] @relation("student")
  fundingRequests  FundingRequest[]
  reputationEvents ReputationEvent[]
  earnings         Earning[]
  walletLinks      WalletLink[]
  notifications    Notification[]
  accounts         Account[]
  sessions         Session[]

  @@index([walletAddress])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model WalletLink {
  id        String   @id @default(cuid())
  userId    String
  wallet    String
  label     String?
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([wallet])
  @@index([userId])
  @@index([wallet])
}

model MentorshipSession {
  id          String   @id @default(cuid())
  mentorId    String
  studentId   String
  topic       String
  duration    Int
  rating      Int?
  txSignature String?  @unique
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  mentor  User @relation("mentor", fields: [mentorId], references: [id])
  student User @relation("student", fields: [studentId], references: [id])

  @@index([mentorId])
  @@index([studentId])
  @@index([txSignature])
}

model FundingRequest {
  id            String   @id @default(cuid())
  userId        String
  amount        Float
  reason        String
  status        String   @default("PENDING")
  voicePitchUrl String?
  onChainId     String?
  txSignature   String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([onChainId])
}

model ReputationEvent {
  id          String   @id @default(cuid())
  userId      String
  action      String
  scoreChange Int
  source      String
  txSignature String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([txSignature])
}

model Earning {
  id          String   @id @default(cuid())
  userId      String
  source      String
  amount      Float
  txSignature String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String?
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
}

model AuditLog {
  id           String   @id @default(cuid())
  action       String
  entityType   String
  entityId     String?
  wallet       String?
  txSignature  String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([action])
  @@index([wallet])
  @@index([txSignature])
  @@index([createdAt])
}
